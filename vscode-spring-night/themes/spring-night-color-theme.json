  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8d9eb2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#a9dd9d"
      }
    },
    {
      "name": "String escape / special char",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#a8d2eb"
      }
    },
    {
      "name": "Number / Boolean / Null",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character"
      ],
      "settings": {
        "foreground": "#fd8489"
      }
    },
    {
      "name": "Constant (other)",
      "scope": [
        "constant"
      ],
      "settings": {
        "foreground": "#fd8489"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.other",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#f0eaaa",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#f0aa8a"
      }
    },
    {
      "name": "Statement / control flow",
      "scope": [
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.return",
        "keyword.control.import",
        "keyword.control.flow",
        "storage.type.function",
        "storage.type.class",
        "keyword.declaration.function",
        "keyword.declaration.class"
      ],
      "settings": {
        "foreground": "#a8d2eb"
      }
    },
    {
      "name": "Function definition",
      "scope": [
        "entity.name.function",
        "meta.function entity.name.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#f0aa8a"
      }
    },
    {
      "name": "Function call",
      "scope": [
        "meta.function-call entity.name.function",
        "meta.method-call entity.name.function"
      ],
      "settings": {
        "foreground": "#f0aa8a"
      }
    },
    {
      "name": "Type / Class",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.struct",
        "entity.name.enum",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#fedf81"
      }
    },
    {
      "name": "Storage type",
      "scope": [
        "storage.type"
      ],
      "settings": {
        "foreground": "#fedf81",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variable / Identifier",
      "scope": [
        "variable",
        "variable.other",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#fffeeb"
      }
    },
    {
      "name": "Constant name (readonly variable)",
      "scope": [
        "variable.other.constant",
        "variable.other.enummember",
        "constant.other"
      ],
      "settings": {
        "foreground": "#fffeeb"
      }
    },
    {
      "name": "Variable parameter",
      "scope": [
        "variable.parameter",
        "meta.function.parameters variable"
      ],
      "settings": {
        "foreground": "#fffeeb"
      }
    },
    {
      "name": "Property / Member",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#fffeeb"
      }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.module"
      ],
      "settings": {
        "foreground": "#f0eaaa"
      }
    },
    {
      "name": "Preprocessor / Macro",
      "scope": [
        "meta.preprocessor",
        "keyword.control.directive",
        "entity.name.function.preprocessor",
        "keyword.other.special-method"
      ],
      "settings": {
        "foreground": "#f0aa8a"
      }
    },
    {
      "name": "Label",
      "scope": [
        "entity.name.label"
      ],
      "settings": {
        "foreground": "#a8d2eb"
      }
    },
    {
      "name": "Tag (HTML/XML)",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#f0aa8a"
      }
    },
    {
      "name": "Tag attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#f0eaaa"
      }
    },
    {
      "name": "Tag punctuation",
      "scope": [
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#8d9eb2"
      }
    },
    {
      "name": "CSS property name",
      "scope": [
        "support.type.property-name",
        "meta.property-name"
      ],
      "settings": {
        "foreground": "#a8d2eb"
      }
    },
    {
      "name": "CSS property value",
      "scope": [
        "support.constant.property-value",
        "meta.property-value"
      ],
      "settings": {
        "foreground": "#f0aa8a"
      }
    },
    {
      "name": "CSS selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css"
      ],
      "settings": {
        "foreground": "#f0eaaa"
      }
    },
    {
      "name": "Invalid / Error",
      "scope": [
        "invalid"
      ],
      "settings": {
        "foreground": "#fd8489",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Special / punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#fffeeb"
      }
    },
    {
      "name": "Markdown heading",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#fedf81",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#fffeeb",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#fffeeb",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code.block"
      ],
      "settings": {
        "foreground": "#f0eaaa"
      }
    },
    {
      "name": "Markdown link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#a8d2eb"
      }
    },
    {
      "name": "Markdown list bullet",
      "scope": [
        "punctuation.definition.list_item"
      ],
      "settings": {
        "foreground": "#f0aa8a"
      }
    },
    {
      "name": "Diff added",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#a9dd9d"
      }
    },
    {
      "name": "Diff removed",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#fd8489"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#f0eaaa"
      }
    },
    {
      "name": "Todo keyword",
      "scope": [
        "keyword.other.todo",
        "comment.line.note"
      ],
      "settings": {
        "foreground": "#132132",
        "background": "#fd8489",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Python builtin",
      "scope": [
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#fd8489"
      }
    },
    {
      "name": "Go builtin",
      "scope": [
        "support.function.builtin.go"
      ],
      "settings": {
        "foreground": "#fd8489"
      }
    },
    {
      "name": "Rust enum variant",
      "scope": [
        "support.constant.rust"
      ],
      "settings": {
        "foreground": "#fedf81"
      }
    },
    {
      "name": "TypeScript async keyword",
      "scope": [
        "storage.modifier.async"
      ],
      "settings": {
        "foreground": "#a8d2eb"
      }
    }
  ],
  "semanticHighlighting": false
}